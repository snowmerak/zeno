{
  "tasks": {
    "dev": "deno run --watch --allow-net --unstable-net --allow-read --allow-write examples/basic-api/main.ts",
    "start": "deno run --allow-net --unstable-net --allow-read --allow-write examples/basic-api/main.ts",
    "test": "deno test --allow-net --unstable-net --allow-read --allow-write",
    "test:watch": "deno test --watch --allow-net --unstable-net --allow-read --allow-write",
    "test:unit": "deno test tests/http/unit --allow-net --unstable-net --allow-read --allow-write",
    "test:integration": "deno test tests/http/integration --allow-net --unstable-net --allow-read --allow-write",
    "test:all": "deno test tests/http --allow-net --unstable-net --allow-read --allow-write",
    "test:net": "deno test tests/net --allow-net --unstable-net --allow-read --allow-write",
    "test:http-client": "deno test tests/http-client --allow-net --unstable-net --allow-read --allow-write",
    "test:db": "deno test tests/db --allow-net --unstable-net --allow-read --allow-write",
    "test:coverage": "deno test tests/http --allow-net --unstable-net --allow-read --allow-write --coverage=coverage && deno coverage coverage --html",
    "bench": "deno bench",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno check **/*.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/log": "jsr:@std/log@0.224",
    "@std/path": "jsr:@std/path@1",
    "@std/testing": "jsr:@std/testing@1"
  },
  "fmt": {
    "options": {
      "useTabs": false,
      "lineWidth": 100,
      "indentWidth": 2,
      "semiColons": true,
      "singleQuote": false
    }
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
